# 后端服务
PORT=3030
# 生产环境部署到阿里云 ECS 时改为 production
NODE_ENV=development

# JWT_SECRET 必填，建议至少 32 个字符；不要在真实项目中使用下面的示例值
JWT_SECRET=replace-with-a-random-secret-at-least-32-chars

# 允许跨域访问的前端域名，多个域名用英文逗号分隔
# 生产环境建议填写真实域名，例如：
# CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
CORS_ORIGIN=http://localhost:5181,http://127.0.0.1:5181,http://localhost:3000,http://127.0.0.1:3000

# Express JSON 请求体上限
REQUEST_BODY_LIMIT=100kb

# LLM 请求超时时间（毫秒）
LLM_TIMEOUT_MS=60000
LLM_STREAM_TIMEOUT_MS=120000

# SiliconFlow：留空时会自动进入 Mock/知识库降级模式
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# DeepSeek：作为备用供应商，留空时不启用
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# PostgreSQL 数据库连接
DATABASE_URL=postgresql://localhost:5432/travel

# 图片 CDN 基础 URL，留空使用本地 /images 目录
# 例如：https://cdn.example.com/images
IMAGE_BASE_URL=

# Sentry 错误监控（前端），留空则不上报
# 从 https://sentry.io 获取 DSN
VITE_SENTRY_DSN=
